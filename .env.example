# Copia este archivo como .env y completa los valores
# NO subas el archivo .env al repositorio

# Base de datos (local: SQLite, producción: ver deploy/env.production.example)
DATABASE_URL="file:./dev.db"

# NextAuth — genera un secret en: https://generate-secret.vercel.app/32
AUTH_SECRET="GENERA_UN_SECRET_AQUI"
NEXTAUTH_URL="http://localhost:3000"

# Email (Gmail con App Password)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="tu-email@gmail.com"
EMAIL_PASS="tu-app-password-de-gmail"
EMAIL_FROM="Nombre <tu-email@gmail.com>"

# Correo del admin/doctora para recibir notificaciones de nuevas solicitudes
ADMIN_EMAIL="correo-de-la-doctora@gmail.com"
# Correo adicional para reenviar notificaciones (dejar vacío si no aplica)
NOTIFY_EMAIL=""

# URL pública de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Allamey Sanz - Psicóloga Clínica"

# Asistente de IA para informes (Claude) — https://console.anthropic.com
# Si se deja vacío, el botón "Asistente IA" devuelve un aviso de no configurado.
ANTHROPIC_API_KEY=""

# Recordatorios automáticos. Un cron del sistema debe llamar:
#   cada ~15 min → /api/cron/recordatorios   (citas 24h y 2h antes)
#   1 vez al día → /api/cron/bitacora         (recordatorio de bitácora emocional)
#   curl -H "Authorization: Bearer <CRON_SECRET>" https://psicoallameysanz.com/api/cron/recordatorios
CRON_SECRET=""

# Web Push — notificaciones al teléfono (PWA). Genera las claves con:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:tu-email@gmail.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""   # = VAPID_PUBLIC_KEY (expuesta al cliente)
