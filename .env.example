# Copia este archivo como .env y completa los valores
# NO subas el archivo .env al repositorio

# Base de datos (local: SQLite, producción: ver deploy/env.production.example)
DATABASE_URL="file:./dev.db"

# NextAuth — genera un secret en: https://generate-secret.vercel.app/32
AUTH_SECRET="GENERA_UN_SECRET_AQUI"
NEXTAUTH_URL="http://localhost:3000"

# Email (Gmail con App Password)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="tu-email@gmail.com"
EMAIL_PASS="tu-app-password-de-gmail"
EMAIL_FROM="Nombre <tu-email@gmail.com>"

# Correo del admin/doctora para recibir notificaciones de nuevas solicitudes
ADMIN_EMAIL="correo-de-la-doctora@gmail.com"

# URL pública de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Allamey Sanz - Psicóloga Clínica"
