generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── AUTENTICACION ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(PACIENTE)
  // Configuración del asistente de IA para informes (solo aplica al ADMIN/doctora)
  iaInstrucciones String?
  iaEjemplo       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  paciente Paciente?
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// ─── WEB PUSH (notificaciones al teléfono) ─────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

enum Role {
  ADMIN
  PACIENTE
}

// ─── PACIENTES ─────────────────────────────────────────────────────────────────

model Paciente {
  id               String    @id @default(cuid())
  codigo           String?   @unique
  userId           String    @unique
  telefono         String?
  fechaNacimiento  DateTime?
  genero           String?
  ocupacion        String?
  direccion        String?
  pais             String?
  quienRemite      String?
  cedula           String?
  primeraConsulta  Boolean   @default(true)
  motivoConsulta   String?
  notas            String?
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  citas           Cita[]
  sesiones        SesionNota[]
  materiales      MaterialAsignado[]
  pagos           Pago[]
  planesCuotas    PlanCuotas[]
  archivos        ArchivoPaciente[]
  consentimiento  ConsentimientoInformado?
  anamnesis       Anamnesis?
  resenas         Resena[]
  registrosEmocionales RegistroEmocional[]

  @@map("pacientes")
}

// ─── BITÁCORA EMOCIONAL ────────────────────────────────────────────────────────

model RegistroEmocional {
  id            String   @id @default(cuid())
  pacienteId    String
  fecha         DateTime @default(now())   // día/momento del registro
  estadoAnimo   Int      // 1=muy mal, 2=mal, 3=neutral, 4=bien, 5=muy bien
  emociones     String?  // JSON array de etiquetas, ej: ["ansiedad","cansancio"]
  desencadenante String? // ¿qué lo provocó?
  nota          String?  // texto libre del paciente
  horasSueno    Float?
  nivelEnergia  Int?     // 1-5
  createdAt     DateTime @default(now())

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([pacienteId])
  @@map("registros_emocionales")
}

// ─── DISPONIBILIDAD ────────────────────────────────────────────────────────────

model Disponibilidad {
  id         String   @id @default(cuid())
  diaSemana  Int
  horaInicio String
  horaFin    String
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("disponibilidad")
}

model BloqueoHorario {
  id         String    @id @default(cuid())
  fecha      DateTime
  horaInicio String?
  horaFin    String?
  todoElDia  Boolean   @default(false)
  motivo     String?
  createdAt  DateTime  @default(now())

  @@map("bloqueos_horario")
}

model ConfiguracionAgenda {
  id                  String   @id @default(cuid())
  duracionIndividual  Int      @default(60)
  duracionPareja      Int      @default(90)
  duracionGrupal      Int      @default(120)
  cupoMaximoDiario    Int      @default(8)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("configuracion_agenda")
}

model PoliticaCancelacion {
  id                String   @id @default(cuid())
  activa            Boolean  @default(false)
  horasAntelacion   Int      @default(24)
  cobrarCancelacion Boolean  @default(false)
  montoCancelacion  Float?
  descripcion       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("politica_cancelacion")
}

// ─── CITAS ─────────────────────────────────────────────────────────────────────

model Cita {
  id             String     @id @default(cuid())
  pacienteId     String
  fecha          DateTime
  duracion       Int        @default(60)
  modalidad      Modalidad  @default(PRESENCIAL)
  estado         EstadoCita @default(PENDIENTE)
  motivoConsulta String?
  notasPaciente  String?
  notasAdmin     String?
  linkSesion     String?
  recordatorio24h Boolean   @default(false)
  recordatorio2h  Boolean   @default(false)
  resenaToken    String?    @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  paciente Paciente    @relation(fields: [pacienteId], references: [id])
  sesion   SesionNota?
  pago     Pago?
  resena   Resena?

  @@map("citas")
}

enum Modalidad {
  PRESENCIAL
  ONLINE
}

enum EstadoCita {
  PENDIENTE
  APROBADA
  RECHAZADA
  REAGENDADA
  COMPLETADA
  CANCELADA
}

// ─── SESIONES / NOTAS CLINICAS ─────────────────────────────────────────────────

model SesionNota {
  id                 String              @id @default(cuid())
  citaId             String?             @unique
  pacienteId         String
  titulo             String              @default("Resumen de Sesion")
  tipoSesion         TipoSesion          @default(INDIVIDUAL)
  contenido              String
  recomendacion          String?
  anotacionesPrivadas    String?
  cantidadSesiones       Int?
  estadoSeguimiento  EstadoSeguimiento?
  publicado          Boolean             @default(false)
  pdfUrl             String?
  fechaSesion        DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  cita     Cita?           @relation(fields: [citaId], references: [id])
  paciente Paciente        @relation(fields: [pacienteId], references: [id])
  archivos SesionArchivo[]

  @@map("sesiones_notas")
}

enum TipoSesion {
  INDIVIDUAL
  PAREJA
  GRUPAL
}

enum EstadoSeguimiento {
  AGENDADA
  CUMPLIDA
  REPROGRAMAR
  CANCELADA
}

model SesionArchivo {
  id        String   @id @default(cuid())
  sesionId  String
  nombre    String
  tipo      String
  url       String
  tamano    Int?
  privado   Boolean  @default(false)
  createdAt DateTime @default(now())

  sesion SesionNota @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@map("sesion_archivos")
}

// ─── CONSENTIMIENTO INFORMADO ───────────────────────────────────────────────────

model ConsentimientoInformado {
  id          String    @id @default(cuid())
  pacienteId  String    @unique
  firmado     Boolean   @default(false)
  fechaFirma  DateTime?
  ipAddress   String?
  firma       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@map("consentimientos")
}

// ─── MATERIALES DIDACTICOS ─────────────────────────────────────────────────────

model Material {
  id          String       @id @default(cuid())
  titulo      String
  descripcion String?
  tipo        TipoMaterial
  contenido   String?
  archivoUrl  String?
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  asignaciones MaterialAsignado[]

  @@map("materiales")
}

model MaterialAsignado {
  id         String    @id @default(cuid())
  materialId String
  pacienteId String
  visto      Boolean   @default(false)
  fechaVisto DateTime?
  createdAt  DateTime  @default(now())

  material Material @relation(fields: [materialId], references: [id])
  paciente Paciente @relation(fields: [pacienteId], references: [id])

  @@unique([materialId, pacienteId])
  @@map("materiales_asignados")
}

enum TipoMaterial {
  PDF
  VIDEO
  ARTICULO
  EJERCICIO
  AUDIO
}

// ─── ANAMNESIS ─────────────────────────────────────────────────────────────────

model Anamnesis {
  id                       String   @id @default(cuid())
  pacienteId               String   @unique

  // Motivo de consulta
  motivoPrincipal          String?
  tiempoEvolucion          String?

  // Antecedentes
  antecedentesMedicos      String?
  antecedentesPsicologicos String?
  medicacionActual         String?

  // Situación actual
  estadoCivil              String?
  hijosCantidad            String?
  situacionLaboral         String?
  nivelEducativo           String?
  redApoyo                 String?

  // Hábitos
  calidadSueno             String?
  actividadFisica          String?
  consumoSustancias        String?

  // Vida afectiva y sexual
  relacionPareja           String?
  vidaSexual               String?

  // Expectativas
  expectativasTerapia      String?
  intentosAnteriores       String?

  // Diagnóstico clínico (completado por la doctora)
  expresionDiagnostica     String?
  patologia                String?

  camposExtra              Json?

  completado               Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@map("anamnesis")
}

// ─── CONFIG ANAMNESIS ──────────────────────────────────────────────────────────

model ConfigAnamnesis {
  id        String   @id @default("singleton")
  campos    Json
  updatedAt DateTime @updatedAt

  @@map("config_anamnesis")
}

// ─── PAGOS ─────────────────────────────────────────────────────────────────────

model PlanCuotas {
  id           String   @id @default(cuid())
  pacienteId   String
  montoTotal   Float
  moneda       Moneda   @default(USD)
  numeroCuotas Int
  descripcion  String?
  createdAt    DateTime @default(now())

  paciente Paciente @relation(fields: [pacienteId], references: [id])
  cuotas   Pago[]

  @@map("planes_cuotas")
}

model Pago {
  id           String     @id @default(cuid())
  citaId       String?    @unique
  pacienteId   String
  planCuotasId String?
  numeroCuota  Int?
  monto        Float
  moneda       Moneda     @default(USD)
  metodoPago   MetodoPago
  estado       EstadoPago @default(PENDIENTE)
  referencia   String?
  notas        String?
  fechaPago    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  cita       Cita?       @relation(fields: [citaId], references: [id])
  paciente   Paciente    @relation(fields: [pacienteId], references: [id])
  planCuotas PlanCuotas? @relation(fields: [planCuotasId], references: [id])

  @@map("pagos")
}

enum MetodoPago {
  ZELLE
  PAGO_MOVIL
  BINANCE
  TRANSFERENCIA_USD
  TRANSFERENCIA_BS
  EFECTIVO
}

enum Moneda {
  USD
  BS
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  CANCELADO
}

enum TipoArchivo {
  DOCUMENTO
  IMAGEN
  URL
  OTRO
}

// ─── GOBERNANZA HYPNOS ─────────────────────────────────────────────────────────

model Licencia {
  id               String       @id @default("singleton")
  plan             PlanLicencia @default(BASICO)
  fechaVencimiento DateTime
  suspendida       Boolean      @default(false)
  notasAdmin       String?
  updatedAt        DateTime     @updatedAt

  pagos PagoLicencia[]

  @@map("licencia")
}

model PagoLicencia {
  id            String   @id @default(cuid())
  licenciaId    String
  monto         Float
  moneda        String   @default("CLP")
  periodoInicio DateTime
  periodoFin    DateTime
  fechaPago     DateTime @default(now())
  notas         String?

  licencia Licencia @relation(fields: [licenciaId], references: [id])

  @@map("pagos_licencia")
}

enum PlanLicencia {
  BASICO
  PRO
  ENTERPRISE
}

model ArchivoPaciente {
  id          String      @id @default(cuid())
  pacienteId  String
  nombre      String
  tipo        TipoArchivo
  url         String
  tamano      Int?
  descripcion String?
  createdAt   DateTime    @default(now())

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@map("archivos_paciente")
}

// ─── RESEÑAS / CALIFICACIONES ──────────────────────────────────────────────────

model Resena {
  id           String    @id @default(cuid())
  pacienteId   String
  citaId       String    @unique
  calificacion Int       // 1=Deficiente, 2=Regular, 3=Bueno, 4=Muy bueno, 5=Excelente
  comentario   String?
  visible      Boolean   @default(true)  // mostrar como testimonio público
  respuesta    String?   // respuesta pública de la doctora
  respondidoEn DateTime?
  createdAt    DateTime  @default(now())

  paciente Paciente @relation(fields: [pacienteId], references: [id])
  cita     Cita     @relation(fields: [citaId], references: [id])

  @@map("resenas")
}

// ─── PERFIL PROFESIONAL (editable) ─────────────────────────────────────────────

model PerfilProfesional {
  id           String   @id @default("singleton")
  nombre       String?  // sobrescribe BRAND.name si se define
  especialidad String?
  bio          String?
  fotoUrl      String?
  infoServicio String?  // descripción del servicio que ve el paciente al agendar
  disclaimer   String?  // aviso/descargo que el paciente acepta
  telefono     String?
  whatsapp     String?
  updatedAt    DateTime @updatedAt

  @@map("perfil_profesional")
}

// ─── CLÁUSULAS DE CONSENTIMIENTO (configurables) ───────────────────────────────

model ClausulaConsentimiento {
  id        String   @id @default(cuid())
  orden     Int      @default(0)
  titulo    String
  texto     String
  activo    Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("clausulas_consentimiento")
}

// ─── PLANTILLAS DE INFORME (modelos para la IA) ────────────────────────────────

model PlantillaInforme {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  contenido   String   // informe modelo de referencia para el estilo/estructura
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("plantillas_informe")
}

// ─── AUDITORÍA ─────────────────────────────────────────────────────────────────

model AuditEntry {
  id           String   @id @default(cuid())
  entidadTipo  String   // "cita" | "pago" | "paciente" | ...
  entidadId    String
  campo        String   // campo que cambió, ej: "estado"
  valorAntes   String?
  valorDespues String?
  userId       String
  userName     String
  createdAt    DateTime @default(now())

  @@index([entidadId])
  @@map("audit_entries")
}
